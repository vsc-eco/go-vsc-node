# syntax=docker/dockerfile:1

# go.mod requires go >= 1.25.7 (toolchain go1.25.10); the 1.24.1 base
# with GOTOOLCHAIN=local fails `go mod download`. Bumped so the devnet
# suite can build. (develop has the same go.mod bump but kept 1.24.1 —
# its own devnet is broken without this; flagged upstream.)
FROM golang:1.25.10 AS build

RUN apt update && apt install -y git python3

RUN useradd -m app
USER app

WORKDIR /home/app/app

# Install Wasmedge: pin to immutable release tag + SHA-256 verify (matches main Dockerfile)
RUN curl -sSfL https://raw.githubusercontent.com/WasmEdge/WasmEdge/0.13.4/utils/install.sh -o /tmp/wasmedge-install.sh && \
    echo "89460d9ea15f097e2831c099ee8adb6975b9ffff8a919b33874a655cd54420c0  /tmp/wasmedge-install.sh" | sha256sum -c - && \
    bash /tmp/wasmedge-install.sh -v 0.13.4 && \
    rm -f /tmp/wasmedge-install.sh

COPY go.mod go.sum ./
RUN go mod download

COPY --chown=app:app . .

# Generate GraphQL code (needed when schema changes) and build all devnet binaries
RUN . /home/app/.wasmedge/env && \
    go run github.com/99designs/gqlgen generate && \
    go build -buildvcs=false -ldflags "-X vsc-node/modules/announcements.GitCommit=$(git rev-parse HEAD)" -o magid vsc-node/cmd/vsc-node && \
    go build -buildvcs=false -o devnet-setup vsc-node/cmd/devnet-setup && \
    go build -buildvcs=false -o genesis-elector vsc-node/cmd/genesis-elector && \
    go build -buildvcs=false -o contract-deployer vsc-node/cmd/contract-deployer && \
    go build -buildvcs=false -o mapping-bot vsc-node/cmd/mapping-bot && \
    go build -buildvcs=false -o feed-publisher vsc-node/cmd/feed-publisher


FROM rockylinux:9.3-minimal

# Install iptables + tc for network partition and latency testing
RUN microdnf install -y iptables iproute iproute-tc && microdnf clean all

RUN useradd -m app

# Create dirs owned by app so Docker volumes inherit correct permissions
RUN mkdir -p /data/mapping-bot /data/devnet && chown app:app /data/mapping-bot /data/devnet

USER app

WORKDIR /home/app/app

COPY --from=build /home/app/app/magid .
COPY --from=build /home/app/app/devnet-setup .
COPY --from=build /home/app/app/genesis-elector .
COPY --from=build /home/app/app/contract-deployer .
COPY --from=build /home/app/app/mapping-bot .
COPY --from=build /home/app/app/feed-publisher .
COPY --from=build /home/app/.wasmedge /home/app/.wasmedge

ENV LD_LIBRARY_PATH=/home/app/.wasmedge/lib:$LD_LIBRARY_PATH
ENV PATH=/home/app/.wasmedge/bin:$PATH

RUN printf '#!/bin/sh\n\
. /home/app/.wasmedge/env\n\
exec "$@"\n' > /home/app/app/entrypoint.sh && \
chmod +x /home/app/app/entrypoint.sh

ENTRYPOINT ["/home/app/app/entrypoint.sh"]
