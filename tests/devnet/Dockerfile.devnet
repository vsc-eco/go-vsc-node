# syntax=docker/dockerfile:1

FROM golang:1.24.1 AS build

RUN apt update && apt install -y git python3

RUN useradd -m app
USER app

WORKDIR /home/app/app

# Install Wasmedge
RUN curl -sSf https://raw.githubusercontent.com/WasmEdge/WasmEdge/master/utils/install.sh | bash -s -- -v 0.13.4

COPY go.mod go.sum ./
RUN go mod download

COPY --chown=app:app . .

# Build all devnet binaries
RUN . /home/app/.wasmedge/env && \
    go build -buildvcs=false -ldflags "-X vsc-node/modules/announcements.GitCommit=$(git rev-parse HEAD)" -o magid vsc-node/cmd/vsc-node && \
    go build -buildvcs=false -o devnet-setup vsc-node/cmd/devnet-setup && \
    go build -buildvcs=false -o genesis-elector vsc-node/cmd/genesis-elector && \
    go build -buildvcs=false -o contract-deployer vsc-node/cmd/contract-deployer && \
    go build -buildvcs=false -o mapping-bot vsc-node/cmd/mapping-bot


FROM rockylinux:9.3-minimal

# Install iptables for network partition testing
RUN microdnf install -y iptables && microdnf clean all

RUN useradd -m app

# Create dirs owned by app so Docker volumes inherit correct permissions
RUN mkdir -p /data/mapping-bot /data/devnet && chown app:app /data/mapping-bot /data/devnet

USER app

WORKDIR /home/app/app

COPY --from=build /home/app/app/magid .
COPY --from=build /home/app/app/devnet-setup .
COPY --from=build /home/app/app/genesis-elector .
COPY --from=build /home/app/app/contract-deployer .
COPY --from=build /home/app/app/mapping-bot .
COPY --from=build /home/app/.wasmedge /home/app/.wasmedge

ENV LD_LIBRARY_PATH=/home/app/.wasmedge/lib:$LD_LIBRARY_PATH
ENV PATH=/home/app/.wasmedge/bin:$PATH

RUN printf '#!/bin/sh\n\
. /home/app/.wasmedge/env\n\
exec "$@"\n' > /home/app/app/entrypoint.sh && \
chmod +x /home/app/app/entrypoint.sh

ENTRYPOINT ["/home/app/app/entrypoint.sh"]
